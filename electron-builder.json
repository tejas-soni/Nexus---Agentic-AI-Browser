{
  "appId": "com.tejas.nexus",
  "productName": "Nexus",
  "directories": {
    "output": "dist"
  },
  "files": [
    "main/**/*",
    "renderer/**/*",
    "preload/**/*",
    "package.json",
    "assets/**/*"
  ],
  "win": {
    "target": ["nsis", "portable"],
    "icon": "assets/icons/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "assets/icons/icon.png",
    "category": "WebBrowser"
  }
}
